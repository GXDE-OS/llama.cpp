#!/usr/bin/make -f
#export DH_VERBOSE = 1
#
# We build the library in multiple passes, one for each backend and/or hwcaps.

# For DEB_VERSION_UPSTREAM
include /usr/share/dpkg/pkg-info.mk

export DEB_BUILD_MAINT_OPTIONS = hardening=+all


PRIVATE_LIBDIR=lib/$(DEB_HOST_MULTIARCH)/llama.cpp

# GGML_NATIVE:ON corresponds to -march=native
OPTS_COMMON        = -DCMAKE_INSTALL_RPATH=/usr/$(PRIVATE_LIBDIR) \
		     -DCMAKE_INSTALL_RPATH_USE_LINK_PATH=OFF \
                     -DGGML_BUILD_NUMBER=$(subst +dfsg,,$(DEB_VERSION_UPSTREAM)) \
		     -DCMAKE_BUILD_TYPE=RelWithDebInfo \
		     -DGGML_NATIVE=OFF

# Baseline turns all optimizations off
ifeq (amd64,$(DEB_HOST_ARCH))
OPTS_BASELINE      = -DCMAKE_INSTALL_LIBDIR=$(PRIVATE_LIBDIR) \
		     -DGGML_SSE42=OFF -DGGML_AVX=OFF -DGGML_AVX2=OFF -DGGML_F16C=OFF -DGGML_FMA=OFF -DGGML_AVX512=OFF
else
# For all other architectures, we don't have anything to turn off
OPTS_BASELINE      = -DCMAKE_INSTALL_LIBDIR=$(PRIVATE_LIBDIR)
endif
BUILDDIR_BASELINE  = build-cpu-baseline


%:
	dh $@ --buildsystem=cmake

override_dh_auto_clean:
	rm -f common/build-info.cpp
	dh_auto_clean --builddir=$(BUILDDIR_BASELINE)

override_dh_auto_configure:
	dh_auto_configure --builddir=$(BUILDDIR_BASELINE) -- $(OPTS_COMMON) $(OPTS_BASELINE)

override_dh_auto_build:
	dh_auto_build --builddir=$(BUILDDIR_BASELINE)

# No tests for now, as many need some kind of model we don't have
override_dh_auto_test:
	:

override_dh_auto_install:
	dh_auto_install --builddir=$(BUILDDIR_BASELINE) --destdir=debian/tmp/$(BUILDDIR_BASELINE)

execute_after_dh_auto_install:
	mkdir -p debian/tmp/usr/bin
	cp convert_hf_to_gguf.py debian/tmp/usr/bin/convert_hf_to_gguf
